# Production API (release builds)
# EXPO_PUBLIC_API_URL=https://tap2crackmaingame-production.up.railway.app

# Local backend — optional in dev. If set to localhost, the app auto-uses your
# PC LAN IP when opened on a phone (e.g. http://192.168.x.x:8081 → API http://192.168.x.x:8000).
EXPO_PUBLIC_DEV_API_URL=http://localhost:8000

# Backend port if not 8000 (e.g. PORT=8080 in TAP2CRACK-BACKEND/.env)
# EXPO_PUBLIC_DEV_API_PORT=8080

# Or set the full LAN URL explicitly (phone on same Wi‑Fi):
# EXPO_PUBLIC_DEV_API_URL=http://192.168.43.28:8000
