# Production API (release builds). Optional in dev if EXPO_PUBLIC_DEV_API_URL is set.
# EXPO_PUBLIC_API_URL=https://tap2crackmaingame-production.up.railway.app

# Local backend — used first in __DEV__ (Expo picks your PC IP on device automatically)
EXPO_PUBLIC_DEV_API_URL=http://localhost:8000

# Physical phone on same Wi‑Fi: use your PC LAN IP, e.g.
# EXPO_PUBLIC_DEV_API_URL=http://192.168.1.42:8000
